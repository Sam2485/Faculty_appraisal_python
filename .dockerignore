# .dockerignore - Files to exclude from Docker build context

# Documentation — all docs live in Docs/, one line covers everything
Docs/

# Dev / tooling
.git
.github
.claude
.venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache

# Admin UI — node_modules are rebuilt inside Docker; dist/ is produced by the build stage
admin_ui/node_modules/

# Infra / config not needed in image
tests/
migrations/
scripts/
cloudbuild.yaml
CLAUDE.md
README.md
.env
.env.example
.python-version
output.txt
